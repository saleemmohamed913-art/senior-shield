rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own profile (including FCM token)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // SOS history subcollection
      match /sosHistory/{sosId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Emergency contacts subcollection
      match /emergencyContacts/{contactId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Tracking sessions — owner can write, anyone with the token can read
    match /trackingSessions/{sessionId} {
      allow create: if request.auth != null;
      allow read: if true; // anyone with link can view
      allow update: if request.auth != null; // auth user can push location updates
      allow delete: if false;
    }
  }
}
