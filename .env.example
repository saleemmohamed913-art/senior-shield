# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google APIs
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key

# Twilio Cloud Function URL (for SMS alerts via Firebase Cloud Functions)
# Format: https://region-projectid.cloudfunctions.net/sendSMS
VITE_CLOUD_FUNCTION_URL=https://us-central1-senior-shield.cloudfunctions.net/sendSMS

# Twilio Credentials (for Cloud Functions deployment, NOT frontend)
# These are used in Firebase Cloud Functions only - DO NOT expose to frontend
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Optional: Backend API URL (if using Node.js backend)
# VITE_API_URL=http://localhost:5000/api

# Environment
VITE_ENV=development

